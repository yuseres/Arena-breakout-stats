<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ABI Tracker | Arena Breakout Infinite Stats</title>
    <style>
        /* Base Theme Styles */
        :root {
            --bg-darken: #0a0c0e;
            --bg-main: #111418;
            --bg-card: #1a1f26;
            --accent-gold: #ce9b38;
            --accent-green: #38ce6c;
            --accent-red: #ce3838;
            --text-main: #e2e8f0;
            --text-muted: #718096;
            --border-color: #2d3748;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-main);
            line-height: 1.6;
        }

        /* Navbar */
        nav {
            background-color: var(--bg-darken);
            border-bottom: 2px solid var(--border-color);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-weight: 800;
            font-size: 1.4rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--text-main);
        }

        .logo span {
            color: var(--accent-gold);
        }

        /* Search Container */
        .search-container {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 1rem;
            display: flex;
            gap: 1rem;
        }

        .search-input {
            flex: 1;
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            padding: 0.8rem 1.2rem;
            color: var(--text-main);
            border-radius: 4px;
            font-size: 1rem;
        }

        .search-input:focus {
            outline: 1px solid var(--accent-gold);
        }

        .search-btn {
            background-color: var(--accent-gold);
            color: #000;
            border: none;
            padding: 0.8rem 2rem;
            font-weight: bold;
            text-transform: uppercase;
            cursor: pointer;
            border-radius: 4px;
            transition: background 0.2s;
        }

        .search-btn:hover {
            background-color: #e2ab3f;
        }

        /* Main Dashboard Grid */
        .dashboard {
            max-width: 1200px;
            margin: 0 auto 3rem auto;
            padding: 0 1rem;
            display: grid;
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        @media (min-width: 768px) {
            .dashboard {
                grid-template-columns: 3fr 1fr;
            }
        }

        /* Card components */
        .card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            padding: 1.5rem;
        }

        .card-title {
            font-size: 1.1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 1.5rem;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 0.5rem;
        }

        /* Profile Header Header */
        .profile-header {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .avatar {
            width: 80px;
            height: 80px;
            background-color: var(--border-color);
            border: 2px solid var(--accent-gold);
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
        }

        .username {
            font-size: 1.8rem;
            font-weight: 700;
        }

        .title-badge {
            color: var(--accent-gold);
            font-size: 0.85rem;
            text-transform: uppercase;
            background: rgba(206, 155, 56, 0.1);
            padding: 0.2rem 0.6rem;
            border-radius: 3px;
            border: 1px solid rgba(206, 155, 56, 0.3);
            display: inline-block;
            margin-top: 0.3rem;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
        }

        @media (min-width: 480px) {
            .stats-grid {
                grid-template-columns: repeat(4, 1fr);
            }
        }

        .stat-box {
            background-color: var(--bg-darken);
            padding: 1rem;
            border-radius: 4px;
            text-align: center;
            border-left: 3px solid var(--accent-gold);
        }

        .stat-value {
            font-size: 1.5rem;
            font-weight: bold;
            color: var(--text-main);
            margin-bottom: 0.2rem;
        }

        .stat-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Financials Card */
        .financial-row {
            display: flex;
            justify-content: space-between;
            padding: 0.8rem 0;
            border-bottom: 1px dashed var(--border-color);
        }

        .financial-row:last-child {
            border-bottom: none;
        }

        .koen-value {
            color: var(--accent-gold);
            font-weight: bold;
        }

        /* Matches Table */
        .table-container {
            overflow-x: auto;
            margin-top: 1.5rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        th {
            color: var(--text-muted);
            font-size: 0.8rem;
            text-transform: uppercase;
            padding: 0.8rem;
            border-bottom: 2px solid var(--border-color);
        }

        td {
            padding: 1rem 0.8rem;
            border-bottom: 1px solid var(--border-color);
            font-size: 0.95rem;
        }

        tr:hover td {
            background-color: rgba(255, 255, 255, 0.02);
        }

        .status-extract {
            color: var(--accent-green);
            font-weight: bold;
        }

        .status-mia {
            color: var(--accent-red);
            font-weight: bold;
        }
    </style>
</head>
<body>

    <!-- Top Navigation -->
    <nav>
        <div class="logo">ABI<span>TRACKER</span></div>
        <div style="color: var(--text-muted); font-size: 0.9rem;">Game Version: Early Access</div>
    </nav>

    <!-- Player Lookup Area -->
    <div class="search-container">
        <input type="text" class="search-input" placeholder="Enter ABI Player Name (e.g., Ghost_Tactical)..." value="Ghost_Tactical">
        <button class="search-btn">Search</button>
    </div>

    <!-- Main Content Area -->
    <div class="dashboard">
        
        <!-- Left Side: Core Stats & Match History -->
        <div style="display: flex; flex-direction: column; gap: 2rem;">
            
            <!-- Player Overview Card -->
            <div class="card">
                <div class="profile-header">
                    <div class="avatar">💀</div>
                    <div>
                        <div class="username">Ghost_Tactical</div>
                        <div class="title-badge">Legendary Contractor</div>
                    </div>
                </div>

                <div class="card-title">Overall Combat Stats</div>
                <div class="stats-grid">
                    <div class="stat-box">
                        <div class="stat-value">62.4%</div>
                        <div class="stat-label">Extract Rate</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-value">5.82</div>
                        <div class="stat-label">K/D Ratio</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-value">342</div>
                        <div class="stat-label">Total Raids</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-value">41.5m</div>
                        <div class="stat-label">Avg. Survive Time</div>
                    </div>
                </div>
            </div>

            <!-- Recent Matches Card -->
            <div class="card">
                <div class="card-title">Recent Raid History</div>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Result</th>
                                <th>Map</th>
                                <th>Loot Value</th>
                                <th>Kills (PMC/Bot)</th>
                                <th>Duration</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="status-extract">EXTRACTED</td>
                                <td>Farm (Lockdown)</td>
                                <td class="koen-value">450,000 Koen</td>
                                <td>3 / 8</td>
                                <td>28:14</td>
                            </tr>
                            <tr>
                                <td class="status-extract">EXTRACTED</td>
                                <td>Valley</td>
                                <td class="koen-value">120,000 Koen</td>
                                <td>1 / 4</td>
                                <td>15:42</td>
                            </tr>
                            <tr>
                                <td class="status-mia">MIA / KILLED</td>
                                <td>Armory</td>
                                <td class="koen-value">0 Koen</td>
                                <td>4 / 2</td>
                                <td>08:22</td>
                            </tr>
                            <tr>
                                <td class="status-extract">EXTRACTED</td>
                                <td>Farm</td>
                                <td class="koen-value">890,000 Koen</td>
                                <td>5 / 12</td>
                                <td>32:01</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>

        <!-- Right Side: Financial / Extra Data Info -->
        <div style="display: flex; flex-direction: column; gap: 2rem;">
            
            <div class="card">
                <div class="card-title">Storage & Economy</div>
                
                <div class="financial-row">
                    <span style="color: var(--text-muted);">Liquid Koen:</span>
                    <span class="koen-value">18,450,000</span>
                </div>
                <div class="financial-row">
                    <span style="color: var(--text-muted);">Storage Value:</span>
                    <span class="koen-value">54,200,000</span>
                </div>
                <div class="financial-row">
                    <span style="color: var(--text-muted);">Avg. Loot / Raid:</span>
                    <span class="koen-value">280,500</span>
                </div>
                <div class="financial-row">
                    <span style="color: var(--text-muted);">Main Weapon:</span>
                    <span>H416 (Meta Build)</span>
                </div>
            </div>

            <div class="card" style="text-align: center; border-color: rgba(206, 155, 56, 0.2);">
                <div style="font-size: 0.85rem; color: var(--accent-gold); text-transform: uppercase; font-weight: bold; margin-bottom: 0.5rem;">Beta Phase Notice</div>
                <p style="font-size: 0.8rem; color: var(--text-muted);">Stats are currently updated manually via community screenshot parsing logs.</p>
            </div>

        </div>

    </div>

</body>
</html>
